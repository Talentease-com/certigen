# Database
DATABASE_URL=postgresql://user:password@host:5432/certigen

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin (comma-separated Better Auth user IDs)
ADMIN_USER_IDS=

# Cloudflare R2 / S3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=certigen
CF_ACCOUNT_ID=
S3_REGION=auto

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=certificates@talentease.com

# App
BASE_URL=http://localhost:3000
